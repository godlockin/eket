# 测试环境 Dockerfile
FROM node:18-alpine

# 安装必要工具
RUN apk add --no-cache \
    git \
    bash \
    python3 \
    make \
    g++

# 设置工作目录
WORKDIR /app

# 复制依赖文件
COPY package*.json ./

# 安装依赖（包括 devDependencies）
RUN npm ci

# 复制源代码
COPY . .

# 构建项目
RUN npm run build

# 设置测试环境变量
ENV NODE_ENV=test
ENV EKET_LOG_LEVEL=error

# 默认命令：运行测试
CMD ["npm", "test"]
