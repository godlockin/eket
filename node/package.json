{
  "name": "eket-cli",
  "version": "2.0.0",
  "description": "EKET Framework CLI - Hybrid Node.js Implementation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node --esm src/index.ts",
    "start": "node dist/index.js",
    "dashboard": "node dist/index.js web:dashboard",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "bench": "ts-node --esm benchmarks/performance-benchmark.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist/"
  },
  "keywords": [
    "eket",
    "cli",
    "agent",
    "framework"
  ],
  "author": "EKET Framework Team",
  "license": "MIT",
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "ajv": "^8.18.0",
    "better-sqlite3": "^11.0.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.0.0",
    "cors": "^2.8.6",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "i18next": "^23.11.5",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "ora": "^9.3.0",
    "proper-lockfile": "^4.1.2",
    "ws": "^8.20.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@types/better-sqlite3": "^7.6.9",
    "@types/cors": "^2.8.19",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.37",
    "@types/proper-lockfile": "^4.1.4",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "babel-jest": "^30.3.0",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "memfs": "^4.57.1",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.58.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8",
    "utf-8-validate": "^6.0.3"
  }
}
