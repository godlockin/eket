# EKET 核心文件
.eket/state/
.eket/logs/
.eket/memory/

# 运行时状态文件（A 类）
jira/state/ticket-index.yml
jira/state/project-status.yml
jira/tickets/feature/*.md
jira/tickets/bugfix/*.md
jira/tickets/fix/*.md
jira/tickets/task/*.md

# 输入/输出文件（A 类）
inbox/human_feedback/*.md
outbox/review_requests/*.md
outbox/tasks/*.md
tasks/*.md

# 临时文件
*.tmp
*.log
*.bak
*.swp
*~

# 系统文件
.DS_Store
Thumbs.db
.Spotlight-V100
.Trashes

# 敏感信息 - 凭证和密钥
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
*.p12
*.pfx
secrets.json
credentials.json
credentials.yml
*.secret
*.secrets

# API 密钥和令牌
api_keys.txt
tokens.json
auth.json

# 数据库文件
*.db
*.sqlite
*.sqlite3
data.db

# 私有配置
private/
*.private
*.local.yml
*.local.json

# 人类反馈中的敏感内容
inbox/human_feedback/*-sensitive.md
inbox/human_feedback/credentials*
inbox/human_feedback/passwords*

# 智能体私有工作区
private/

# 构建产物
dist/
build/
*.o
*.so
*.dylib

# 依赖
node_modules/
vendor/
.venv/
venv/
__pycache__/

# IDE
.idea/
.vscode/
*.sublime-*

# 智能体消息队列（运行时产物，不追踪）
shared/message_queue/inbox/
shared/message_queue/outbox/
shared/message_queue/broadcast/
shared/message_queue/dead_letter/

# Agent Memory - local 级别（个人私有知识，不追踪）
# user 级别存储在 ~/.claude/agent-memory/，天然不在仓库中
# project 级别（.claude/agent-memory/）追踪，用于团队共享
.claude/agent-memory-local/
