# EKET E2E Demo 环境变量

# EKET Server 配置
EKET_SERVER_URL=http://localhost:8080
EKET_SERVER_PORT=8080
EKET_SERVER_HOST=localhost

# JWT Secret (用于 API 认证)
OPENCLAW_API_KEY=demo-secret-key-1234567890

# Redis 配置
EKET_REDIS_HOST=localhost
EKET_REDIS_PORT=6379

# 日志配置
EKET_LOG_LEVEL=info
EKET_LOG_DIR=./logs

# WebSocket 配置
EKET_WEBSOCKET_ENABLED=true

# Agent 配置
AGENT_HEARTBEAT_INTERVAL=30
AGENT_WORK_DELAY=3

# 可选：调试模式
# DEBUG=eket:*
