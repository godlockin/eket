{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://eket.dev/schemas/agent_registration.json",
  "title": "Agent Registration",
  "description": "Schema for agent registration request",
  "type": "object",
  "required": ["agent_type", "role"],
  "properties": {
    "agent_type": {
      "type": "string",
      "description": "Type of the AI agent",
      "enum": ["claude_code", "openclaw", "cursor", "windsurf", "gemini", "custom"],
      "examples": ["claude_code", "openclaw"]
    },
    "agent_version": {
      "type": "string",
      "description": "Version of the agent tool",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["1.0.0", "2.1.3"]
    },
    "role": {
      "type": "string",
      "description": "Role of the agent in the collaboration",
      "enum": ["master", "slaver"]
    },
    "specialty": {
      "type": "string",
      "description": "Specialty area for slaver agents",
      "enum": ["frontend", "backend", "fullstack", "qa", "devops", "designer", "general"],
      "examples": ["frontend", "backend"]
    },
    "capabilities": {
      "type": "array",
      "description": "Technical capabilities of the agent",
      "items": {
        "type": "string"
      },
      "examples": [["react", "typescript", "python"]]
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata about the agent",
      "properties": {
        "user": {
          "type": "string",
          "description": "Username of the person running the agent"
        },
        "machine": {
          "type": "string",
          "description": "Hostname of the machine"
        },
        "timezone": {
          "type": "string",
          "description": "Timezone of the agent",
          "examples": ["Asia/Shanghai", "America/New_York"]
        }
      }
    },
    "protocol_version": {
      "type": "string",
      "description": "EKET protocol version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "default": "1.0.0"
    }
  }
}
