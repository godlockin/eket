{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://eket.dev/schemas/task.json",
  "title": "EKET Task",
  "description": "Schema for task definition",
  "type": "object",
  "required": ["id", "title", "type", "status"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Task identifier",
      "pattern": "^[A-Z]+-\\d+$",
      "examples": ["FEAT-001", "FIX-042", "TASK-123"]
    },
    "title": {
      "type": "string",
      "description": "Task title",
      "minLength": 1,
      "maxLength": 200
    },
    "type": {
      "type": "string",
      "description": "Task type",
      "enum": ["feature", "bugfix", "task", "test", "doc", "refactor"]
    },
    "priority": {
      "type": "string",
      "description": "Task priority",
      "enum": ["P0", "P1", "P2", "P3"],
      "default": "P2"
    },
    "status": {
      "type": "string",
      "description": "Current task status",
      "enum": ["backlog", "ready", "in_progress", "review", "done"]
    },
    "assigned_to": {
      "type": "string",
      "description": "Instance ID of assigned agent",
      "examples": ["slaver_frontend_001"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Task creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp"
    },
    "description": {
      "type": "string",
      "description": "Detailed task description"
    },
    "acceptance_criteria": {
      "type": "array",
      "description": "List of acceptance criteria",
      "items": {
        "type": "object",
        "required": ["description", "completed"],
        "properties": {
          "description": {
            "type": "string"
          },
          "completed": {
            "type": "boolean"
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "description": "Task tags for categorization",
      "items": {
        "type": "string"
      },
      "examples": [["frontend", "react", "authentication"]]
    },
    "estimate": {
      "type": "string",
      "description": "Estimated effort (e.g., '8h', '2d')",
      "pattern": "^\\d+[hdw]$",
      "examples": ["8h", "2d", "1w"]
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "requires": {
          "type": "array",
          "description": "Tasks that must complete before this one",
          "items": {
            "type": "string",
            "pattern": "^[A-Z]+-\\d+$"
          }
        },
        "blocks": {
          "type": "array",
          "description": "Tasks blocked by this one",
          "items": {
            "type": "string",
            "pattern": "^[A-Z]+-\\d+$"
          }
        }
      }
    }
  }
}
