{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentRegistration",
  "type": "object",
  "required": ["agent_type", "role"],
  "properties": {
    "agent_type": {
      "type": "string",
      "enum": ["claude_code", "cursor", "windsurf", "copilot", "gemini", "custom"]
    },
    "role": {
      "type": "string",
      "enum": ["master", "slaver"]
    },
    "specialty": {
      "type": "string"
    },
    "agent_version": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
