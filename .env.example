# EKET Framework 环境变量配置示例
# 复制此文件为 .env 并填入实际值
#
# 安全提示：
# - 不要将 .env 文件提交到版本控制
# - 使用强随机密码和 API Key
# - 定期轮换密钥

# =============================================================================
# OpenCLAW Gateway 配置
# =============================================================================

# API Key - 用于保护 API 端点
# 生成安全 Key: openssl rand -hex 16 或 node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OPENCLAW_API_KEY=your-secure-api-key-here-at-least-32-chars

# Gateway 服务配置
EKET_OPENCLAW_ENABLED=true
EKET_OPENCLAW_MODE=autonomous
EKET_OPENCLAW_GATEWAY_PORT=8080
EKET_OPENCLAW_GATEWAY_HOST=localhost

# 认证配置
EKET_OPENCLAW_AUTH_TYPE=api_key
EKET_OPENCLAW_API_KEY_ENV=OPENCLAW_API_KEY

# =============================================================================
# Redis 配置
# =============================================================================

# Redis 连接配置
EKET_REDIS_HOST=localhost
EKET_REDIS_PORT=6379
EKET_REDIS_PASSWORD=your-redis-password-if-needed
EKET_REDIS_DB=0

# Redis TLS 配置（生产环境推荐启用）
# EKET_REDIS_TLS=true
# EKET_REDIS_CA_CERT=/path/to/ca-cert.pem

# =============================================================================
# SQLite 配置
# =============================================================================

# SQLite 数据库路径
EKET_SQLITE_PATH=~/.eket/data/sqlite/eket.db

# =============================================================================
# 消息队列配置
# =============================================================================

EKET_OPENCLAW_MQ_TYPE=redis
EKET_OPENCLAW_MQ_HOST=localhost
EKET_OPENCLAW_MQ_PORT=6379
EKET_OPENCLAW_MQ_PASSWORD=your-redis-password

# 消息队列通道
EKET_OPENCLAW_MQ_CHANNEL_TASK_ASSIGNMENT=openclaw:tasks:assign
EKET_OPENCLAW_MQ_CHANNEL_STATUS_UPDATE=openclaw:tasks:status
EKET_OPENCLAW_MQ_CHANNEL_AGENT_LIFECYCLE=openclaw:agents:lifecycle

# =============================================================================
# Agent 配置
# =============================================================================

EKET_OPENCLAW_AUTO_SPAWN=true
EKET_OPENCLAW_MAX_CONCURRENT=5
EKET_OPENCLAW_IDLE_TIMEOUT=3600

# =============================================================================
# 安全配置
# =============================================================================

# 启用速率限制
EKET_RATE_LIMIT_ENABLED=true
EKET_RATE_LIMIT_WINDOW_MS=900000
EKET_RATE_LIMIT_MAX_REQUESTS=100

# 启用安全响应头
EKET_SECURITY_HEADERS_ENABLED=true

# =============================================================================
# 日志配置
# =============================================================================

LOG_LEVEL=info
LOG_FILE=~/.eket/logs/eket.log
