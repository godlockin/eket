#!/usr/bin/env bash
# EKET pre-commit hook
# Install: ln -sf ../../.githooks/pre-commit .git/hooks/pre-commit
# Or:      git config core.hooksPath .githooks

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# 1) 需求分析硬校验 — 若 commit 包含新 EPIC 目录，必须六节齐全 + ticket INVEST 字段齐全
if [[ -x scripts/check-requirement-analysis.sh ]]; then
  bash scripts/check-requirement-analysis.sh --staged || {
    echo ""
    echo "pre-commit: 需求分析未通过，参考 template/docs/EXPERT-PANEL-PLAYBOOK.md"
    echo "绕过（不推荐）: git commit --no-verify"
    exit 1
  }
fi

# 1b) Ticket 元数据不可变字段校验 — Slaver 不得修改 priority/AC/blocked_by 等
if [[ -x scripts/check-ticket-immutability.sh ]]; then
  bash scripts/check-ticket-immutability.sh --staged || {
    echo ""
    echo "pre-commit: ticket 不可变字段被修改"
    exit 1
  }
fi

# 1c) Workflow YAML 校验 — 防止 .github/workflows/*.yml 损坏 (PR #77→#81 教训)
staged_wf=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^\.github/workflows/.*\.ya?ml$' || true)
if [[ -n "$staged_wf" && -x scripts/lint-workflows.sh ]]; then
  # shellcheck disable=SC2086
  bash scripts/lint-workflows.sh $staged_wf || {
    echo ""
    echo "pre-commit: workflow YAML 校验失败 (duplicate step / parse error)"
    echo "参考: PR #77 corruption / TASK-054"
    exit 1
  }
fi

# 2) 复盘 hook — 若 ticket 从 in_progress/review 切到 done 必须同时更新 confluence/memory
if [[ -x scripts/check-debrief.sh ]]; then
  # 只在 HEAD 存在时运行（新仓库首次 commit 跳过）
  if git rev-parse HEAD >/dev/null 2>&1; then
    bash scripts/check-debrief.sh HEAD HEAD 2>/dev/null || true   # pre-commit 阶段 staged 尚未 commit，此处仅 warn
  fi
fi

exit 0
